{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure",
      "type": "shell",
      "command": "cmake",
      "args": ["-S", ".", "-B", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "run",
      "type": "shell",
      "command": "${workspaceFolder}/build/StudentCourseManager",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "build",
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "panel": "shared",
        "reveal": "always"
      }
    },
    {
      "label": "test",
      "type": "shell",
      "command": "${workspaceFolder}/build/StudentCourseManagerTests",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "build",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
